# ==================== البيانات الحساسة الأساسية ====================
BOT_TOKEN=
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/sinfora_db
API_KEY=
OWNER_ID=

# ==================== إعدادات قاعدة البيانات ====================
REDIS_URL=

# ==================== إعدادات البوت ====================
BOT_NAME=سـنـفورة ٱلـبـَنـات
BOT_DESCRIPTION=بوت ذكي متقدم يدعم شخصيات متعددة والذكاء الاصطناعي
WELCOME_MESSAGE=مرحباً بك! أنا سـنـفورة ٱلـبـَنـات، بوت ذكي متقدم. اختر شخصية للبدء.
BASE_URL=https://api.openai.com/v1/chat/completions
MODEL=gpt-4o-mini

# ==================== إدارة البوت ====================
ADMIN_LIST=
MAINTENANCE_MODE=false

# ==================== تحديد السعة ====================
RATE_LIMIT_MESSAGES=30
RATE_LIMIT_WINDOW=60
FREE_MESSAGES=100

# ==================== إعدادات السجلات ====================
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# ==================== متغيرات Railway الجديدة ====================
TZ=Asia/Amman
MAX_CONCURRENT_TASKS=2
START_FROM_LATEST=true
